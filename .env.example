# =============================================================================
# VETERAN - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_URL=http://localhost:7860
PORT=3000
DATA_PATH=/data

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://veteran:veteran_secret@localhost:5432/veteran

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Security / Encryption
# ---------------------------------------------------------------------------
APP_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------------------------------------------------------
# Supabase (Optional - for Supabase BaaS features)
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# OAuth Providers
# ---------------------------------------------------------------------------

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_ORGS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitLab OAuth
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_URL=https://gitlab.com

# Bitbucket OAuth
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_ALLOWED_GUILD_ID=

# Microsoft Azure AD OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Generic OIDC
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email / SMTP
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@veteran.app
EMAIL_NAME=VETERAN

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_PROVIDER=local
STORAGE_S3_ENDPOINT=
STORAL_S3_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_FORCE_PATH_STYLE=false

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------
REGISTRATION_ENABLED=true
REGISTRATION_DOMAIN_WHITELIST=
REGISTRATION_INVITE_ONLY=false
CODESPACES_ENABLED=true
ACTIONS_ENABLED=true
PACKAGES_ENABLED=true
WIKIS_ENABLED=true
DISCUSSIONS_ENABLED=true
PROJECTS_ENABLED=true
PAGES_ENABLED=false

# ---------------------------------------------------------------------------
# Git Configuration
# ---------------------------------------------------------------------------
GIT_MAX_PUSH_SIZE=500
GIT_MAX_FILE_SIZE=100
GIT_LFS_ENABLED=true
GIT_LFS_MAX_STORAGE=50
GIT_SSH_HOST=0.0.0.0
GIT_SSH_PORT=2222
GIT_SSH_HOST_KEY_PATH=/data/ssh/ssh_host_ed25519_key

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
ADMIN_USERNAMES=
ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Codespaces
# ---------------------------------------------------------------------------
CODESPACE_DEFAULT_MACHINE=2-core
CODESPACE_MAX_MACHINE=16-core
CODESPACE_IDLE_TIMEOUT_MINUTES=30
CODESPACE_MAX_LIFETIME_HOURS=8
CODESPACE_STORAGE_LIMIT_GB=32
CODESPACE_CONTAINER_IMAGE=mcr.microsoft.com/devcontainers/universal:2
CODESPACE_DOCKER_NETWORK=veteran-codespaces

# ---------------------------------------------------------------------------
# CI / Actions
# ---------------------------------------------------------------------------
CI_RUNNER_CONCURRENCY=4
CI_JOB_TIMEOUT_MINUTES=60
CI_ARTIFACT_RETENTION_DAYS=90
CI_LOG_RETENTION_DAYS=30
CI_DEFAULT_CONTAINER_IMAGE=node:20-alpine
CI_ENABLED=true

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_PAYLOAD_SIZE_LIMIT_KB=256

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Email Templates
# ---------------------------------------------------------------------------
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h
PASSWORD_RESET_TOKEN_EXPIRES_IN=1h

# ---------------------------------------------------------------------------
# Upload
# ---------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf
